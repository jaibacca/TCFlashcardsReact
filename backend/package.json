{
  "name": "tcflashcards-backend",
  "version": "1.0.0",
  "description": "Backend API for Traditional Chinese Flashcards app",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "init-db": "node scripts/init-db.js",
    "init-db-production": "node scripts/init-db-production.js",
    "seed-db": "node scripts/seed-db.js",
    "setup": "npm run init-db && npm run seed-db",
    "setup-production": "npm run init-db-production && npm run seed-db"
  },
  "keywords": ["flashcards", "chinese", "api", "postgresql"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.3",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.2"
  }
}
